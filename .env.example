# --- OCS Management ---

# Secret used to sign session cookies. REQUIRED in production.
# Generate one with: openssl rand -hex 32
OCSM_AUTH_SECRET=

# Optional bootstrap admin. If no users exist yet, signing in with these
# credentials creates the first admin user automatically.
OCSM_ADMIN_USERNAME=
OCSM_ADMIN_PASSWORD=

# Production content storage (GitHub). If both are set, content/users/theme are
# read and written via the GitHub API instead of the local filesystem.
OCSM_GITHUB_TOKEN=
OCSM_GITHUB_REPO=owner/repo
OCSM_GITHUB_BRANCH=main
